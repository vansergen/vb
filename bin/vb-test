  setup_case "volume_names_with_dots_and_dashes"

  local volume_name="alpha.beta-gamma"
  local ts="20250101_090004"
  local archive="$TEST_BACKUP_ROOT/${volume_name}_${ts}.tar.gz"

  make_volume_content "$volume_name"

  run_backup -v "$volume_name" -T "$ts" -c || return 1
