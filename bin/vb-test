  setup_case "backup_timestamp_env_var"

  make_volume_content "alpha"

  local ts="20250101_090005"
  local archive="$TEST_BACKUP_ROOT/alpha_${ts}.tar.gz"

  run_backup_with_env BACKUP_TIMESTAMP="$ts" -- -v alpha -c || return 1
  assert_file_exists "$archive" || return 1
}

test_invalid_flags_and_missing_args() {
  setup_case "invalid_flags_and_missing_args"

  make_volume_content "alpha"

  set +e
  run_backup -z >/dev/null 2>&1
  local backup_invalid_flag_rc=$?
  run_backup -v >/dev/null 2>&1
  local backup_missing_arg_rc=$?
  run_restore -z >/dev/null 2>&1
  local restore_invalid_flag_rc=$?
  run_restore -i "$TEST_BACKUP_ROOT/missing.tar" >/dev/null 2>&1
  local restore_missing_arg_rc=$?
  set -e

  (( backup_invalid_flag_rc != 0 )) || return 1
  (( backup_missing_arg_rc != 0 )) || return 1
  (( restore_invalid_flag_rc != 0 )) || return 1
  (( restore_missing_arg_rc != 0 )) || return 1
}

test_s3_roundtrip_optional() {
  s3_tests_enabled || return "$SKIP_RC"

  setup_case "s3_roundtrip_optional"

  make_volume_content "alpha"

  local ts="20250101_040000"
  local base_prefix="${TEST_S3_PREFIX:-docker-volume-tests}"
  base_prefix="${base_prefix#/}"
  base_prefix="${base_prefix%/}"

  local suffix="$(date +%Y%m%d-%H%M%S)-$$-${RANDOM}"
  local prefix="$suffix"
  if [[ -n "$base_prefix" ]]; then
    prefix="${base_prefix}/${suffix}"
  fi

  local key="alpha_${ts}.tar.gz"
  local s3_uri="s3://${TEST_S3_BUCKET}/${prefix}/${key}"

  run_backup -v alpha -T "$ts" -c -b "$TEST_S3_BUCKET" -f "$prefix" || return 1

  run_restore -i "$s3_uri" -t alpha_restore -C || return 1
  assert_dirs_equal "$TEST_VOLUMES_ROOT/alpha" "$TEST_VOLUMES_ROOT/alpha_restore" || return 1
}

test_s3_roundtrip_encrypted_optional() {
  s3_tests_enabled || return "$SKIP_RC"
  command -v gpg >/dev/null 2>&1 || return "$SKIP_RC"

  setup_case "s3_roundtrip_encrypted_optional"

  make_volume_content "alpha"
  export GPG_PASSPHRASE="test-s3-encrypted-passphrase"

  local ts="20250101_090006"
  local base_prefix="${TEST_S3_PREFIX:-docker-volume-tests}"
  base_prefix="${base_prefix#/}"
  base_prefix="${base_prefix%/}"

  local suffix="enc-$(date +%Y%m%d-%H%M%S)-$$-${RANDOM}"
  local prefix="$suffix"
  if [[ -n "$base_prefix" ]]; then
    prefix="${base_prefix}/${suffix}"
  fi

  local key="alpha_${ts}.tar.gz.gpg"
  local s3_uri="s3://${TEST_S3_BUCKET}/${prefix}/${key}"

  run_backup -v alpha -T "$ts" -c -s -b "$TEST_S3_BUCKET" -f "$prefix" || return 1

  run_restore -i "$s3_uri" -t alpha_restore -s -C || return 1
  assert_dirs_equal "$TEST_VOLUMES_ROOT/alpha" "$TEST_VOLUMES_ROOT/alpha_restore" || return 1
}

# ------------------------------------------------------------------------------
# Test runner
# ------------------------------------------------------------------------------

run_test() {
  local name="$1"
  shift

  TESTS_TOTAL=$((TESTS_TOTAL + 1))

  set +e
  "$@"
  local rc=$?
  set -e

  case "$rc" in
    0)
      TESTS_PASSED=$((TESTS_PASSED + 1))
      pass "$name"
      ;;
    "$SKIP_RC")
      TESTS_SKIPPED=$((TESTS_SKIPPED + 1))
      skip "$name"
      ;;
    *)
      TESTS_FAILED=$((TESTS_FAILED + 1))
      fail "$name"
      ;;
  esac
}

# ------------------------------------------------------------------------------
# Preflight
# ------------------------------------------------------------------------------

[[ -f "$BACKUP_BIN" ]] || die "Backup script not found: $BACKUP_BIN"
[[ -f "$RESTORE_BIN" ]] || die "Restore script not found: $RESTORE_BIN"

require_command bash
require_command tar
require_command find
require_command diff

if ! command -v gzip >/dev/null 2>&1 && ! command -v pigz >/dev/null 2>&1; then
  die "Neither gzip nor pigz found; compressed tests cannot run"
fi

log "Using backup script:  $BACKUP_BIN"
log "Using restore script: $RESTORE_BIN"
log "Test root: $TEST_ROOT"

# ------------------------------------------------------------------------------
# Execute tests
# ------------------------------------------------------------------------------

run_test "single backup/restore plain"              test_single_backup_restore_plain
run_test "single backup/restore compressed"         test_single_backup_restore_compressed
run_test "single backup/restore symmetric"          test_single_backup_restore_symmetric
run_test "single backup/restore asymmetric"         test_single_backup_restore_asymmetric
run_test "all-mode filters + parallel"              test_all_mode_with_filters_and_parallel
run_test "backup single dry-run"                    test_backup_single_dry_run_creates_nothing
run_test "backup all dry-run"                       test_backup_all_dry_run_creates_nothing
